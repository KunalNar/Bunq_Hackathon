# ── Required API keys ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
BUNQ_API_KEY=sandbox_...

# ── bunq configuration ─────────────────────────────────────────────────────────
BUNQ_ENVIRONMENT=SANDBOX   # SANDBOX or PRODUCTION
BUNQ_DEVICE_DESCRIPTION=bunq-hackathon-demo

# ── App behaviour ──────────────────────────────────────────────────────────────
# Set to "true" to use fixtures/transactions.json instead of hitting real sandbox
MOCK_MODE=true
# Port for the FastAPI server
PORT=8000

# ── Voice fallbacks ────────────────────────────────────────────────────────────
# Set USE_KOKORO_TTS=true to use Kokoro-82M locally.
USE_KOKORO_TTS=false
KOKORO_LANG_CODE=a
KOKORO_REPO_ID=hexgrad/Kokoro-82M
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.0
KOKORO_DEVICE=cpu

# Recommended fallback for offline demos on macOS if you don't want OpenAI.
USE_LOCAL_WHISPER=false
WHISPER_MODEL=base
USE_MACOS_TTS=false
